# ============================================================
# doubtundo.app — Environment Variables
# Copy this to .env and fill in real values
# ============================================================

# Supabase (separate project from padikkunnundo.in)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# JWT SSO — must match the secret used on padikkunnundo.in
JWT_SECRET=your-shared-hs256-secret-here

# Flask
FLASK_SECRET_KEY=change-this-to-a-long-random-string
FLASK_ENV=production
DEBUG=false

# Session (filesystem for single-instance Render free tier)
SESSION_TYPE=filesystem
SESSION_FILE_DIR=/tmp/flask_sessions
SESSION_PERMANENT=true
SESSION_LIFETIME_DAYS=7

# Admin auto-promotion (comma-separated emails)
ADMIN_EMAILS=admin@mariancollege.ac.in

# Optional: padikkunnundo.in base URL (for redirect-back on auth failure)
PADIKKU_BASE_URL=https://padikkunnundo.in
